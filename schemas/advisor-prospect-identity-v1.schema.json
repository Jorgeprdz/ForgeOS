    "relationshipReferences":{"type":"array"},"context":{"type":"array"},"createdAt":{"type":"string"},"updatedAt":{"type":"string"},"version":{"type":"integer","minimum":1},"privacyClassification":{"const":"FORGE_CONFIDENTIAL_PROSPECT"}
  }
}
