{
  "$schema":"https://json-schema.org/draft/2020-12/schema",
  "$id":"https://forge-os.local/schemas/advisor-prospect-identity-v1.schema.json",
  "title":"Advisor OS Prospect Identity V1","type":"object","additionalProperties":false,
