{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://forge-os.local/schemas/precontract.schema.json",
  "title": "Forge Precontract",
  "description": "Precontract lifecycle and progress contract. Rules come from Organization Profile / Office Rules Config, not hardcoded defaults.",
  "type": "object",
  "additionalProperties": true,
  "required": ["precontractId", "candidateId", "managerId", "lifecycle", "progress", "contractReadiness"],
  "properties": {
    "precontractId": {
      "type": "string",
      "description": "Stable precontract process identifier.",
      "examples": ["PRECONTRACT_001"]
    },
    "candidateId": {
      "type": "string",
      "description": "Candidate in precontract process.",
      "examples": ["CANDIDATE_001"]
    },
    "advisorId": {
      "type": ["string", "null"],
      "description": "Advisor identifier if already assigned.",
      "examples": ["ADVISOR_TEMP_001"]
    },
    "managerId": {
      "type": "string",
      "description": "Responsible manager.",
      "examples": ["MANAGER_001"]
    },
    "organizationProfileId": {
      "type": ["string", "null"],
      "description": "Organization profile that owns precontract rules.",
      "examples": ["ORG_PROFILE_DEMO_001"]
    },
    "officeRulesConfigId": {
      "type": ["string", "null"],
      "description": "Office-specific rules config used to evaluate this cycle.",
      "examples": ["OFFICE_RULES_DEMO_001"]
    },
    "startDate": {
      "type": ["string", "null"],
      "description": "Compatibility alias for the active cycle start date. Prefer lifecycle.informalStartDate or lifecycle.keyActivationDate.",
      "examples": ["2026-06-01T00:00:00.000Z"]
    },
    "deadlineDate": {
      "type": ["string", "null"],
      "description": "Compatibility alias for the active cycle deadline. Prefer lifecycle.officialWindowEndDate or lifecycle.keyExpirationDate.",
      "examples": ["2026-08-30T00:00:00.000Z"]
    },
    "lifecycle": {
      "type": "object",
      "description": "Precontract lifecycle dates and status. This supports informal starts, key activation, expiration, reactivation and multiple cycles.",
      "additionalProperties": true,
      "required": ["cycleId", "lifecycleStage"],
      "properties": {
        "cycleId": { "type": "string", "examples": ["PRECONTRACT_CYCLE_DEMO_001"] },
        "lifecycleStage": {
          "type": "string",
          "enum": ["INFORMAL", "KEY_ACTIVE", "OFFICIAL_WINDOW", "KEY_EXPIRED", "REACTIVATED", "CLOSED", "UNKNOWN"],
          "examples": ["OFFICIAL_WINDOW"]
        },
        "informalStartDate": { "type": ["string", "null"], "examples": ["2026-05-15T00:00:00.000Z"] },
        "keyActivationDate": { "type": ["string", "null"], "examples": ["2026-06-01T00:00:00.000Z"] },
        "officialWindowStartDate": { "type": ["string", "null"], "examples": ["2026-06-01T00:00:00.000Z"] },
        "officialWindowEndDate": { "type": ["string", "null"], "examples": ["2026-08-30T00:00:00.000Z"] },
        "keyExpirationDate": { "type": ["string", "null"], "examples": ["2026-08-30T00:00:00.000Z"] },
        "keyReactivationDate": { "type": ["string", "null"], "examples": ["2026-09-15T00:00:00.000Z"] }
      }
    },
    "officeRulesSnapshot": {
      "type": "object",
      "description": "Snapshot of configurable organization or office rules used for this evaluation. Values are not global Forge constants.",
      "additionalProperties": true,
      "properties": {
        "officialWindowDays": { "type": ["number", "null"] },
        "minimumPolicies": { "type": ["number", "null"] },
        "minimumCommissionsMxn": { "type": ["number", "null"] },
        "currency": { "type": ["string", "null"], "examples": ["MXN"] }
      }
    },
    "cycleHistory": {
      "type": "array",
      "description": "Accumulated history across one or more precontract cycles.",
      "items": {
        "type": "object",
        "additionalProperties": true,
        "properties": {
          "cycleId": { "type": "string", "examples": ["PRECONTRACT_CYCLE_DEMO_001"] },
          "stage": { "type": "string", "examples": ["OFFICIAL_WINDOW"] },
          "startedAt": { "type": ["string", "null"], "examples": ["2026-06-01T00:00:00.000Z"] },
          "endedAt": { "type": ["string", "null"], "examples": ["2026-08-30T00:00:00.000Z"] },
          "outcome": { "type": ["string", "null"], "examples": ["AT_RISK"] }
        }
      }
    },
    "progress": {
      "type": "object",
      "description": "Current measurable progress. Values must come from explicit data.",
      "additionalProperties": true,
      "required": ["policiesIssued", "commissionsMxn"],
      "properties": {
        "policiesIssued": { "type": "number", "minimum": 0, "examples": [5] },
        "commissionsMxn": { "type": "number", "minimum": 0, "examples": [15000] },
        "daysElapsed": { "type": ["number", "null"], "minimum": 0, "examples": [42] },
        "daysRemaining": { "type": ["number", "null"], "minimum": 0, "examples": [48] }
      }
    },
    "contractReadiness": {
      "type": "string",
      "enum": ["READY", "ON_TRACK", "AT_RISK", "NOT_READY", "UNKNOWN"],
      "description": "Readiness classification.",
      "examples": ["AT_RISK"]
    },
    "risk": {
      "type": ["string", "null"],
      "enum": ["LOW", "MEDIUM", "HIGH", "UNKNOWN", null],
      "description": "Precontract success risk.",
      "examples": ["MEDIUM"]
    },
    "probabilityOfSuccess": {
      "type": ["number", "null"],
      "minimum": 0,
      "maximum": 100,
      "description": "Probability estimate from explicit progress and rules.",
      "examples": [62]
    },
    "nextAction": {
      "type": "object",
      "description": "Manager action to move precontract forward.",
      "additionalProperties": true,
      "required": ["action", "reason"],
      "properties": {
        "action": { "type": "string", "examples": ["REVIEW_PIPELINE"] },
        "reason": { "type": "string", "examples": ["Candidate needs three more policies before the deadline."] }
      }
    },
    "confidence": {
      "type": ["number", "null"],
      "minimum": 0,
      "maximum": 100,
      "examples": [70]
    }
  },
  "examples": [
    {
      "precontractId": "PRECONTRACT_001",
      "candidateId": "CANDIDATE_001",
      "managerId": "MANAGER_001",
      "organizationProfileId": "ORG_PROFILE_001",
      "officeRulesConfigId": "OFFICE_RULES_001",
      "lifecycle": {
        "cycleId": "PRECONTRACT_CYCLE_001",
        "lifecycleStage": "OFFICIAL_WINDOW",
        "informalStartDate": "2026-05-15T00:00:00.000Z",
        "keyActivationDate": "2026-06-01T00:00:00.000Z",
        "officialWindowStartDate": "2026-06-01T00:00:00.000Z",
        "officialWindowEndDate": "2026-08-30T00:00:00.000Z",
        "keyExpirationDate": "2026-08-30T00:00:00.000Z"
      },
      "officeRulesSnapshot": {
        "officialWindowDays": 75,
        "minimumPolicies": 6,
        "minimumCommissionsMxn": 18000,
        "currency": "MXN"
      },
      "progress": {
        "policiesIssued": 5,
        "commissionsMxn": 15000,
        "daysElapsed": 42,
        "daysRemaining": 48
      },
      "contractReadiness": "AT_RISK",
      "risk": "MEDIUM",
      "probabilityOfSuccess": 62,
      "nextAction": {
        "action": "REVIEW_PIPELINE",
        "reason": "Candidate needs three more policies before the deadline."
      },
      "confidence": 70
    }
  ]
}
