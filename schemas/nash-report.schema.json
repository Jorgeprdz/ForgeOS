{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://forge-os.local/schemas/nash-report.schema.json",
  "title": "Forge NASH Report",
  "description": "Contract for NASH master conversation intelligence output.",
  "type": "object",
  "additionalProperties": true,
  "required": ["engine", "version", "advisor", "prospect", "intent", "nextBestAction", "confidence"],
  "properties": {
    "engine": {
      "type": "string",
      "const": "NASH_MASTER_INTELLIGENCE_ENGINE",
      "examples": ["NASH_MASTER_INTELLIGENCE_ENGINE"]
    },
    "version": {
      "type": "string",
      "examples": ["1.0"]
    },
    "advisor": {
      "type": "object",
      "additionalProperties": true,
      "required": ["advisorId"],
      "properties": {
        "advisorId": { "type": "string", "examples": ["ADVISOR_JORGE_001"] },
        "performanceScore": { "type": ["number", "null"], "examples": [74] },
        "biggestBottleneck": { "type": ["string", "null"], "examples": ["FOLLOWUP"] }
      }
    },
    "prospect": {
      "type": "object",
      "additionalProperties": true,
      "required": ["prospectId"],
      "properties": {
        "prospectId": { "type": "string", "examples": ["PROSPECT_MARIA_001"] },
        "context": { "type": "object", "additionalProperties": true },
        "memoryPatterns": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "conversations": { "type": "number", "examples": [2] },
            "objections": { "type": "number", "examples": [1] },
            "lastOutcome": { "type": ["string", "null"], "examples": ["NEEDS_RESPONSE"] }
          }
        }
      }
    },
    "personality": {
      "type": "object",
      "description": "Personality output from NASH personality engine.",
      "additionalProperties": true
    },
    "intent": {
      "type": "object",
      "description": "Intent output from NASH intent engine. AI connectors must not modify this.",
      "additionalProperties": true,
      "required": ["primaryIntent"],
      "properties": {
        "primaryIntent": { "type": "string", "examples": ["REAL_BUDGET_CONSTRAINT"] },
        "confidence": { "type": ["number", "null"], "minimum": 0, "maximum": 100, "examples": [80] },
        "possibleIntents": { "type": "array", "items": { "type": "string" } }
      }
    },
    "objection": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "type": { "type": ["string", "null"], "examples": ["FINANCIAL"] },
        "text": { "type": ["string", "null"], "examples": ["I do not have money right now."] },
        "response": { "type": ["string", "null"], "examples": ["I understand. Let's separate cash flow from priority."] }
      }
    },
    "psychology": {
      "type": "object",
      "description": "Psychology explanation generated by NASH combat intelligence.",
      "additionalProperties": true
    },
    "recommendedResponse": {
      "type": ["string", "null"],
      "description": "Structured NASH recommended response.",
      "examples": ["I understand. Let's separate cash flow from priority."]
    },
    "nextBestAction": {
      "type": "object",
      "description": "Authoritative next action. AI must not change this.",
      "additionalProperties": true,
      "required": ["action"],
      "properties": {
        "action": { "type": "string", "examples": ["ASK_CLARIFYING_QUESTION"] },
        "reason": { "type": ["string", "null"], "examples": ["Clarify whether this is cash flow or priority."] }
      }
    },
    "advisorInsight": { "type": "object", "additionalProperties": true },
    "coachingInsight": { "type": "object", "additionalProperties": true },
    "managerInsight": { "type": "object", "additionalProperties": true },
    "teamInsight": { "type": "object", "additionalProperties": true },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 100,
      "examples": [78]
    }
  },
  "examples": [
    {
      "engine": "NASH_MASTER_INTELLIGENCE_ENGINE",
      "version": "1.0",
      "advisor": {
        "advisorId": "ADVISOR_JORGE_001",
        "performanceScore": 74,
        "biggestBottleneck": "FOLLOWUP"
      },
      "prospect": {
        "prospectId": "PROSPECT_MARIA_001",
        "context": {},
        "memoryPatterns": {
          "conversations": 2,
          "objections": 1,
          "lastOutcome": "NEEDS_RESPONSE"
        }
      },
      "personality": {
        "personality": "PROTECTOR",
        "confidence": 85
      },
      "intent": {
        "primaryIntent": "REAL_BUDGET_CONSTRAINT",
        "confidence": 80
      },
      "nextBestAction": {
        "action": "ASK_CLARIFYING_QUESTION",
        "reason": "Clarify whether this is cash flow or priority."
      },
      "confidence": 78
    }
  ]
}
